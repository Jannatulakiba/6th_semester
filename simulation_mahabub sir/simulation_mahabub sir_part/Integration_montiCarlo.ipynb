   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "a, b, N = 2, 5, 1200\n",
    "\n",
    "\n",
    "def f(x):\n",
    "    return x**3\n",
    "\n",
    "\n",
    "x_random = np.random.uniform(a, b, N)\n",
    "estimate = (b - a) * np.mean(f(x_random))\n",
    "\n",
    "print(f\"Monte Carlo Estimate: {estimate:.4f}\")"
   ]
